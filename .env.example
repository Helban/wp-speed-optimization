# Copy to .env and adjust. Local development only — these are not real secrets.
WP_PORT=8080

WP_DB_NAME=wordpress
WP_DB_USER=wp
WP_DB_PASSWORD=change_me_local
WP_DB_ROOT_PASSWORD=change_me_root_local

# Site identity (the "before" demo brand)
WP_SITE_URL=http://localhost:8080
WP_SITE_TITLE=Greenfield Landscaping
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change_me_admin_local
WP_ADMIN_EMAIL=admin@example.com
